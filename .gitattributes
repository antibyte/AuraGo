# Normalize line endings: LF in repository, platform-native on checkout
* text=auto
.gitattributes text eol=lf

# Force LF for all shell scripts regardless of OS
*.sh    text eol=lf
*.bash  text eol=lf
docker-entrypoint.sh text eol=lf

# Go source files use LF
*.go    text eol=lf

# Markdown
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf

# Generated frontend bundles are written with LF by scripts/build-ui-bundles.js.
ui/css/*.bundle.css text eol=lf
ui/js/chat/bundles/*.js text eol=lf
ui/js/chat/main.js text eol=lf
ui/js/desktop/bundles/*.js text eol=lf

# Binaries — never convert
*.exe   binary
bin/aurago_linux        binary
bin/lifeboat_linux      binary
bin/config-merger_linux binary
bin/aurago_linux_arm64        binary
bin/lifeboat_linux_arm64      binary
bin/config-merger_linux_arm64 binary
