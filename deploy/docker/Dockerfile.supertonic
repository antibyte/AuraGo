FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install "supertonic[serve]==1.3.1"

RUN mkdir -p /root/.cache

EXPOSE 7788

CMD ["supertonic", "serve", "--host", "0.0.0.0", "--port", "7788", "--model", "supertonic-3"]
